# Supabase — backend uses the service-role key (bypasses RLS).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# LLM provider injection. See canvasai/llm/provider.py for the registry.
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Inngest
INNGEST_APP_ID=canvasai
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# CORS — comma-free JSON list
CORS_ORIGINS=["http://localhost:3000"]
