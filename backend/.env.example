# Supabase — backend uses the service-role key (bypasses RLS).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# LLM Provider Switch
LLM_PROVIDER="gemini"
GEMINI_API_KEY="your_gemni_key"
GEMINI_MODEL="gemini-3-flash-lite"
OPENAI_API_KEY="your_openai_key"

# Inngest
INNGEST_APP_ID=canvasai
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# CORS — comma-free JSON list
CORS_ORIGINS=["http://localhost:3000"]

# LangSmith Tracing 
LANGCHAIN_TRACING_V2="true"
LANGCHAIN_ENDPOINT="https://api.smith.langchain.com"
LANGCHAIN_API_KEY="your_key"
LANGCHAIN_PROJECT="CanvasAI-Hackathon"